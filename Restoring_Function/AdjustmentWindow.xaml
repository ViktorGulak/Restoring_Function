<Window x:Class="Restoring_Function.AdjustmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restoring_Function"
        mc:Ignorable="d"
        Title="AdjustmentWindow" Height="450" Width="530">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопка загрузки из файла с обновлённой подсказкой -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button x:Name="LoadFromFileButton" 
                    Content="📂 Загрузить из файла" 
                    Padding="10,5" Height="27" VerticalAlignment="Top" Click="LoadFromFileButton_Click"/>
            <TextBlock Text=" (формат: первая строка — X, вторая — Y, разделитель ';')" 
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Foreground="Gray"
                       FontStyle="Italic"/>
        </StackPanel>

        <!-- DataGrid для ввода данных -->
        <DataGrid x:Name="InputDataGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  Margin="0,0,0,10" 
                  HorizontalScrollBarVisibility="Hidden">

            <DataGrid.Columns>
                <!-- Столбец X -->
                <DataGridTextColumn Header="X" 
                                    Binding="{Binding X, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                    Width="1*">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Margin" Value="5,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- Столбец Y -->
                <DataGridTextColumn Header="Y" 
                                    Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                    Width="*">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Margin" Value="5,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель для погрешности -->
        <Border Grid.Row="2" 
                Background="#F0F0F0" 
                Padding="10" 
                CornerRadius="5" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Погрешность δ:" 
                           VerticalAlignment="Center" 
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>

                <TextBox x:Name="DeltaTextBox" 
                         Grid.Column="1"
                         Padding="5,3"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Подсказка по вводу -->
        <TextBlock Grid.Row="2" 
                   Text="(если погрешность неизвестна, оставьте 0 или пустым)"
                   Foreground="Gray"
                   FontSize="11"
                   FontStyle="Italic"
                   HorizontalAlignment="Right"
                   Margin="0,30,0,0"/>

        <!-- Нижняя панель с кнопками -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,10,0,0">
            <Button x:Name="SaveButton" 
                    Content="💾 Сохранить" 
                    Padding="15,8"
                    IsDefault="True"
                    Background="LightGreen" Height="34" Margin="0,0,0,-0.4" VerticalAlignment="Top" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
